[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	shallow = true
	branch = HEAD
[submodule "dnapath"]
	path = dnapath
	url = https://github.com/cran/dnapath
	shallow = true
	registered = true
[submodule "SeqNet"]
	path = SeqNet
	url = https://github.com/cran/SeqNet
	shallow = true
	registered = true
